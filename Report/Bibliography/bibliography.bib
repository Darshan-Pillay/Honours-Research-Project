@article{jafarRevolutionizingAgricultureArtificial2024,
  title = {Revolutionizing Agriculture with Artificial Intelligence: Plant Disease Detection Methods, Applications, and Their Limitations},
  shorttitle = {Revolutionizing Agriculture with Artificial Intelligence},
  author = {Jafar, Abbas and Bibi, Nabila and Naqvi, Rizwan Ali and Sadeghi-Niaraki, Abolghasem and Jeong, Daesik},
  date = {2024-03-13},
  journaltitle = {Frontiers in Plant Science},
  shortjournal = {Front. Plant Sci.},
  volume = {15},
  publisher = {Frontiers},
  issn = {1664-462X},
