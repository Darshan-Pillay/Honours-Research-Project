@article{fonteijnAutomaticPhenotypingTomatoes2021,
  title = {Automatic {{Phenotyping}} of {{Tomatoes}} in {{Production Greenhouses Using Robotics}} and {{Computer Vision}}: {{From Theory}} to {{Practice}}},
