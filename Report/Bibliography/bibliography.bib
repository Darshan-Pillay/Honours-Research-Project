  author = {Haworth, Matthew and Marino, Giovanni and Atzori, Giulia and Fabbri, Andre and Daccache, Andre and Killi, Dilek and Carli, Andrea and Montesano, Vincenzo and Conte, Adriano and Balestrini, Raffaella and Centritto, Mauro},
  date = {2023-01},
  journaltitle = {Plants},
  volume = {12},
  number = {23},
  pages = {4015},
  publisher = {Multidisciplinary Digital Publishing Institute},
  issn = {2223-7747},
  doi = {10.3390/plants12234015},
  url = {https://www.mdpi.com/2223-7747/12/23/4015},
  urldate = {2025-05-21},
  abstract = {Plant physiological status is the interaction between the plant genome and the prevailing growth conditions. Accurate characterization of plant physiology is, therefore, fundamental to effective plant phenotyping studies; particularly those focused on identifying traits associated with improved yield, lower input requirements, and climate resilience. Here, we outline the approaches used to assess plant physiology and how these techniques of direct empirical observations of processes such as photosynthetic CO2 assimilation, stomatal conductance, photosystem II electron transport, or the effectiveness of protective energy dissipation mechanisms are unsuited to high-throughput phenotyping applications. Novel optical sensors, remote/proximal sensing (multi- and hyperspectral reflectance, infrared thermography, sun-induced fluorescence), LiDAR, and automated analyses of below-ground development offer the possibility to infer plant physiological status and growth. However, there are limitations to such ‘indirect’ approaches to gauging plant physiology. These methodologies that are appropriate for the rapid high temporal screening of a number of crop varieties over a wide spatial scale do still require ‘calibration’ or ‘validation’ with direct empirical measurement of plant physiological status. The use of deep-learning and artificial intelligence approaches may enable the effective synthesis of large multivariate datasets to more accurately quantify physiological characters rapidly in high numbers of replicate plants. Advances in automated data collection and subsequent data processing represent an opportunity for plant phenotyping efforts to fully integrate fundamental physiological data into vital efforts to ensure food and agro-economic sustainability.},
  issue = {23},
  langid = {english},
  keywords = {climate resilience,deep-learning,hyperspectral,LiDAR,partial least squares regression,phenomics,photosynthesis,plant ecophysiology,Plant Physiology,spectral reflectance},
  file = {/Users/darshanpillay/Zotero/storage/VNZ3MLM3/Haworth et al. - 2023 - Plant Physiological Analysis to Overcome Limitations to Plant Phenotyping.pdf}
}

