@inproceedings{papeUtilizingMachineLearning2015,
  title = {Utilizing Machine Learning Approaches to Improve the Prediction of Leaf Counts and Individual Leaf Segmentation of Rosette Plant Images},
  booktitle = {Procedings of the {{Proceedings}} of the {{Computer Vision Problems}} in {{Plant Phenotyping Workshop}} 2015},
