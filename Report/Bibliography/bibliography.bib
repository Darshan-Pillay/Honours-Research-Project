  keywords = {Applications In Low-cost automated Greenhouses},
  file = {/Users/darshanpillay/Zotero/storage/MGFIXBZX/Du et al. - 2021 - Greenhouse-based vegetable high-throughput phenotyping platform and trait evaluation for large-scale.pdf}
