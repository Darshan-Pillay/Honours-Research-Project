@inproceedings{rameshPlantDiseaseDetection2018,
  title = {Plant {{Disease Detection Using Machine Learning}}},
  booktitle = {2018 {{International Conference}} on {{Design Innovations}} for {{3Cs Compute Communicate Control}} ({{ICDI3C}})},
  author = {Ramesh, Shima and Hebbar, Ramachandra and M., Niveditha and R., Pooja and N., Prasad Bhat and N., Shashank and P.V., Vinod},
