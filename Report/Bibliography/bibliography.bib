@article{wangImageSegmentationOverlapping2018,
  title = {Image Segmentation of Overlapping Leaves Based on {{Chan}}–{{Vese}} Model and {{Sobel}} Operator},
  author = {Wang, Zhibin and Wang, Kaiyi and Yang, Feng and Pan, Shouhui and Han, Yanyun},
  date = {2018-03-01},
  journaltitle = {Information Processing in Agriculture},
