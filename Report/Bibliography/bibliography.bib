@article{fahlgrenVersatilePhenotypingSystem2015,
  title = {A {{Versatile Phenotyping System}} and {{Analytics Platform Reveals Diverse Temporal Responses}} to {{Water Availability}} in {{Setaria}}},
  author = {Fahlgren, Noah and Feldman, Maximilian and Gehan, Malia A. and Wilson, Melinda S. and Shyu, Christine and Bryant, Douglas W. and Hill, Steven T. and McEntee, Colton J. and Warnasooriya, Sankalpi N. and Kumar, Indrajit and Ficor, Tracy and Turnipseed, Stephanie and Gilbert, Kerrigan B. and Brutnell, Thomas P. and Carrington, James C. and Mockler, Todd C. and Baxter, Ivan},
  date = {2015-10-05},
  journaltitle = {Molecular Plant},
  shortjournal = {Molecular Plant},
  volume = {8},
