  author = {Czedik-Eysenberg, Angelika and Seitner, Sebastian and Güldener, Ulrich and Koemeda, Stefanie and Jez, Jakub and Colombini, Martin and Djamei, Armin},
  date = {2018},
  journaltitle = {New Phytologist},
