  booktitle = {Plant {{Disease Management Strategies}} for {{Sustainable Agriculture}} through {{Traditional}} and {{Modern Approaches}}},
  author = {Balasundram, Siva K. and Golhani, Kamlesh and Shamshiri, Redmond R. and Vadamalai, Ganesan},
