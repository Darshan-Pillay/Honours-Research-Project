  author = {Du, Jianjun and Fan, Jiangchuan and Wang, Chuanyu and Lu, Xianju and Zhang, Ying and Wen, Weiliang and Liao, Shengjin and Yang, Xiaozeng and Guo, Xinyu and Zhao, Chunjiang},
