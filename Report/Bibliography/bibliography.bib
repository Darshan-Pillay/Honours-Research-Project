  author = {Al Hiary, H. and Bani Ahmad, S. and Reyalat, M. and Braik, M. and ALRahamneh, Z.},
  date = {2011-03-31},
  journaltitle = {International Journal of Computer Applications},
  shortjournal = {IJCA},
  volume = {17},
  number = {1},
