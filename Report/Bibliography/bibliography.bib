@article{muller-linowPlantScreenMobile2019,
  title = {Plant {{Screen Mobile}}: An Open-Source Mobile Device App for Plant Trait Analysis},
  shorttitle = {Plant {{Screen Mobile}}},
  author = {Müller-Linow, Mark and Wilhelm, Jens and Briese, Christoph and Wojciechowski, Tobias and Schurr, Ulrich and Fiorani, Fabio},
  date = {2019-12},
  journaltitle = {Plant Methods},
