@article{minerviniPhenotikiOpenSoftware2017,
  title = {Phenotiki: An Open Software and Hardware Platform for Affordable and Easy Image-Based Phenotyping of Rosette-Shaped Plants},
  shorttitle = {Phenotiki},
  author = {Minervini, Massimo and Giuffrida, Mario V. and Perata, Pierdomenico and Tsaftaris, Sotirios A.},
  date = {2017},
  journaltitle = {The Plant Journal},
  volume = {90},
  number = {1},
  pages = {204--216},
  issn = {1365-313X},
  doi = {10.1111/tpj.13472},
  url = {https://onlinelibrary.wiley.com/doi/abs/10.1111/tpj.13472},
  urldate = {2025-07-25},
  abstract = {Phenotyping is important to understand plant biology, but current solutions are costly, not versatile or are difficult to deploy. To solve this problem, we present Phenotiki, an affordable system for plant phenotyping that, relying on off-the-shelf parts, provides an easy to install and maintain platform, offering an out-of-box experience for a well-established phenotyping need: imaging rosette-shaped plants. The accompanying software (with available source code) processes data originating from our device seamlessly and automatically. Our software relies on machine learning to devise robust algorithms, and includes an automated leaf count obtained from 2D images without the need of depth (3D). Our affordable device ( €200) can be deployed in growth chambers or greenhouse to acquire optical 2D images of approximately up to 60 adult Arabidopsis rosettes concurrently. Data from the device are processed remotely on a workstation or via a cloud application (based on CyVerse). In this paper, we present a proof-of-concept validation experiment on top-view images of 24 Arabidopsis plants in a combination of genotypes that has not been compared previously. Phenotypic analysis with respect to morphology, growth, color and leaf count has not been performed comprehensively before now. We confirm the findings of others on some of the extracted traits, showing that we can phenotype at reduced cost. We also perform extensive validations with external measurements and with higher fidelity equipment, and find no loss in statistical accuracy when we use the affordable setting that we propose. Device set-up instructions and analysis software are publicly available ( http://phenotiki.com).},
  langid = {english},
  keywords = {affordable,Arabidopsis thaliana,growth,image analysis,Methodology,phenotyping,Raspberry Pi,software,technical advance},
  file = {/Users/darshanpillay/Zotero/storage/NQP996HG/Minervini et al. - 2017 - Phenotiki an open software and hardware platform for affordable and easy image-based phenotyping of.pdf;/Users/darshanpillay/Zotero/storage/GFQENSSV/tpj.html}
}

